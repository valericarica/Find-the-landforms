```html
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explorator Geografic 3D</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { margin: 0; overflow: hidden; background-color: #000; font-family: sans-serif; }
        canvas { display: block; }
        
        /* Interfața */
        .ui-container {
            position: absolute;
            inset: 0;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 25px;
            z-index: 10;
        }

        .stats-card {
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(10px);
            padding: 20px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            width: fit-content;
            pointer-events: auto;
            color: white;
        }

        /* Tinta din centrul ecranului */
        .crosshair {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 40px;
            height: 40px;
            transform: translate(-50%, -50%);
            border: 2px solid rgba(255, 255, 255, 0.5);
            border-radius: 50%;
            pointer-events: none;
        }
        .crosshair::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 4px;
            height: 4px;
            background: #ffcc00;
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }

        .action-button {
            background: #3b82f6;
            color: white;
            padding: 15px 40px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1.2rem;
            pointer-events: auto;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
            margin: 0 auto;
        }
        .action-button:hover { background: #2563eb; transform: scale(1.05); }
        .action-button:active { transform: scale(0.95); }

        #message-box {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.9);
            padding: 30px;
            border-radius: 20px;
            border: 2px solid #3b82f6;
            color: white;
            text-align: center;
            display: none;
            z-index: 100;
            max-width: 80%;
        }
    </style>
</head>
<body>

    <div class="crosshair"></div>

    <div class="ui-container">
        <div class="stats-card">
            <h1 class="text-xl font-bold text-blue-400">🌍 EXPLORATOR</h1>
            <p class="text-xs text-gray-400 mt-1 uppercase tracking-tighter">Obiectiv curent:</p>
            <p id="target-name" class="text-2xl font-black text-yellow-400 leading-tight">Căutare...</p>
            <p class="mt-2 text-sm">Scor: <span id="score" class="font-bold text-green-400">0</span></p>
        </div>

        <button class="action-button" onclick="checkSelection()">IDENTIFICĂ LOCAȚIA</button>
    </div>

    <div id="message-box"></div>

    <script>
        let scene, camera, renderer, globe, clouds, controls;
        let score = 0;
        let currentTarget = null;
        let markers = [];
        
        const landmarks = [
            { name: "Munții Himalaya", lat: 28, lon: 86, desc: "Acoperișul lumii, unde se află vârful Everest." },
            { name: "Marea Barieră de Corali", lat: -18, lon: 147, desc: "Cea mai mare structură vie de pe Pământ, vizibilă din spațiu." },
            { name: "Deșertul Sahara", lat: 23, lon: 12, desc: "Cel mai mare deșert arid din lume." },
            { name: "Bazinul Amazonului", lat: -3, lon: -60, desc: "Plămânul planetei, cea mai mare pădure tropicală." },
            { name: "Delta Dunării", lat: 45, lon: 29, desc: "Un paradis al biodiversității în România." },
            { name: "Munții Anzi", lat: -32, lon: -70, desc: "Cel mai lung lanț muntos continental." },
            { name: "Insula Madagascar", lat: -18, lon: 47, desc: "Un tărâm izolat cu specii de animale unice în lume." },
            { name: "Marele Canion", lat: 36, lon: -112, desc: "O minune geologică sculptată în Arizona, SUA." }
        ];

        function init() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 2000);
            camera.position.z = 250;

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            document.body.appendChild(renderer.domElement);

            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const sunLight = new THREE.DirectionalLight(0xffffff, 1);
            sunLight.position.set(5, 3, 5);
            scene.add(sunLight);

            const loader = new THREE.TextureLoader();
            
            // Globul cu textură satelit
            const earthTexture = loader.load('https://unpkg.com/three-globe/example/img/earth-blue-marble.jpg');
            const bumpMap = loader.load('https://unpkg.com/three-globe/example/img/earth-topology.png');
            
            const globeGeo = new THREE.SphereGeometry(100, 64, 64);
            const globeMat = new THREE.MeshPhongMaterial({
                map: earthTexture,
                bumpMap: bumpMap,
                bumpScale: 2,
                specular: new THREE.Color('grey'),
                shininess: 5
            });
            globe = new THREE.Mesh(globeGeo, globeMat);
            scene.add(globe);

            // Nori
            const cloudTexture = loader.load('https://raw.githubusercontent.com/mrdoob/three.js/master/examples/textures/planets/earth_clouds_2048.png');
            clouds = new THREE.Mesh(
                new THREE.SphereGeometry(101, 64, 64),
                new THREE.MeshPhongMaterial({ map: cloudTexture, transparent: true, opacity: 0.3 })
            );
            scene.add(clouds);

            // Markeri vizibili pentru ajutor
            landmarks.forEach(loc => {
                const pos = latLonToVector3(loc.lat, loc.lon, 100.5);
                const marker = new THREE.Mesh(
                    new THREE.SphereGeometry(1.5, 12, 12),
                    new THREE.MeshBasicMaterial({ color: 0xffcc00 })
                );
                marker.position.copy(pos);
                marker.userData = loc;
                globe.add(marker);
                markers.push(marker);
            });

            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.minDistance = 130;
            controls.maxDistance = 400;

            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });

            setNewTarget();
            animate();
        }

        function latLonToVector3(lat, lon, radius) {
            const phi = (90 - lat) * (Math.PI / 180);
            const theta = (lon + 180) * (Math.PI / 180);
            return new THREE.Vector3(
                -radius * Math.sin(phi) * Math.cos(theta),
                radius * Math.cos(phi),
                radius * Math.sin(phi) * Math.sin(theta)
            );
        }

        function checkSelection() {
            // Raycaster din centrul camerei
            const raycaster = new THREE.Raycaster();
            raycaster.setFromCamera(new THREE.Vector2(0, 0), camera);

            const intersects = raycaster.intersectObjects(globe.children);

            let found = false;
            if (intersects.length > 0) {
                // Verificăm dacă cel mai apropiat punct lovit este ținta noastră
                // Sau dacă suntem foarte aproape de coordonatele țintei
                for (let i = 0; i < markers.length; i++) {
                    const m = markers[i];
                    const distance = intersects[0].point.distanceTo(m.getWorldPosition(new THREE.Vector3()));
                    
                    if (distance < 15 && m.userData.name === currentTarget.name) {
                        found = true;
                        success(m.userData);
                        break;
                    }
                }
            }

            if (!found) {
                showMessage("Mai caută! Nu ești exact deasupra locației corecte.", "#ef4444");
            }
        }

        function success(landmark) {
            score += 100;
            document.getElementById('score').innerText = score;
            showMessage(`✅ CORECT!<br><br><strong>${landmark.name}</strong><br>${landmark.desc}`, "#22c55e");
            setTimeout(setNewTarget, 3000);
        }

        function showMessage(text, color) {
            const box = document.getElementById('message-box');
            box.innerHTML = text;
            box.style.borderColor = color;
            box.style.display = 'block';
            setTimeout(() => box.style.display = 'none', 3000);
        }

        function setNewTarget() {
            const last = currentTarget;
            while(currentTarget === last) {
                currentTarget = landmarks[Math.floor(Math.random() * landmarks.length)];
            }
            document.getElementById('target-name').innerText = currentTarget.name;
        }

        function animate() {
            requestAnimationFrame(animate);
            if (clouds) clouds.rotation.y += 0.0001;
            controls.update();
            renderer.render(scene, camera);
        }

        window.onload = init;
    </script>
</body>
</html>

